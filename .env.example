OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=openai
OPENAI_BASE_URL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MONGODB_URI=mongodb://localhost:27017/revops_ai
SENDGRID_API_KEY=mock_key
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_gmail_address@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=true
MAIL_SSL=false
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_RETRIES=2
RETRY_DELAY=1.0
FAISS_INDEX_PATH=./memory/faiss_index
CONFIDENCE_THRESHOLD=0.6

# --- Authentication ---
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
AUTH_SECRET_KEY=change-me-please-use-a-long-random-string
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_COOKIE_NAME=revops_access_token
AUTH_REFRESH_COOKIE_NAME=revops_refresh_token
AUTH_COOKIE_SAMESITE=lax
AUTH_ISSUER=revops-ai
AUTH_AUDIENCE=revops-ai-api
# AUTH_COOKIE_SECURE=true        # uncomment in production
# AUTH_COOKIE_DOMAIN=localhost    # set to your domain in production

# --- Password Policy ---
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPER=true
AUTH_PASSWORD_REQUIRE_LOWER=true
AUTH_PASSWORD_REQUIRE_DIGIT=true
AUTH_PASSWORD_REQUIRE_SPECIAL=true

# --- Rate Limiting ---
GLOBAL_RATE_LIMIT_REQUESTS_PER_MINUTE=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# --- Pagination ---
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# --- Memory ---
MEMORY_TTL_SECONDS=604800
MEMORY_MAX_DOCUMENTS_PER_USER=200
MEMORY_MAX_TOTAL_DOCUMENTS=5000
